rules_version = '2';

// Terabi (ترابي) — Firestore security rules
// Paste this into Firebase Console → Firestore Database → Rules → Publish
// (or deploy with `firebase deploy --only firestore:rules` if you use the CLI).
//
// Model: public read (anyone can browse the catalog), authenticated write.
// The app signs users in anonymously on launch (see lib/main.dart), so no
// login screen is required — this just blocks random scripts/bots that only
// have your Firebase web config (which is not a secret, but open rules let
// anyone read/write/delete everything through it).

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(data) {
      return isSignedIn() && data.createdBy == request.auth.uid;
    }

    function isValidProduct(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.price is number && data.price >= 0
        && data.category is string
        && data.phone is string && data.phone.size() <= 30
        && data.imageUrls is list && data.imageUrls.size() <= 20
        && data.createdBy == request.auth.uid;
    }

    match /products/{productId} {
      // Anyone can browse the catalog — no auth needed to read.
      allow read: if true;

      // Only signed-in clients (anonymous auth counts) can create, and only
      // with well-formed data stamped with their own uid.
      allow create: if isSignedIn() && isValidProduct(request.resource.data);

      // Only the original poster (same device/session that created it) can
      // edit or delete it. The app has no edit/delete UI yet — this is
      // defense-in-depth against direct API/script abuse.
      allow update, delete: if isOwner(resource.data);
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
