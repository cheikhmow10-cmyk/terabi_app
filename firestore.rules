rules_version = '2';

// VAZA (فازا) — Firestore security rules
// Paste this into Firebase Console → Firestore Database → Rules → Publish
// (or deploy with `firebase deploy --only firestore:rules` if you use the CLI).
//
// Model: public read (anyone can browse the catalog), admin-only write.
// The app has no anonymous auth and no public sign-up — the only way to
// obtain a session at all is signing in as the one admin account via the
// /admin login screen (see lib/screens/admin_login_page.dart), so gating
// writes on that specific email is the actual enforcement, not just a UI
// convenience.

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'cheikhmow10@gmail.com';
    }

    function isValidProduct(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.price is number && data.price >= 0
        && data.category is string
        && data.phone is string && data.phone.size() <= 30
        && data.imageUrls is list && data.imageUrls.size() <= 20;
    }

    match /products/{productId} {
      // Anyone can browse the catalog — no auth needed to read.
      allow read: if true;

      // Only the admin account can create, update, or delete products.
      allow create, update, delete: if isAdmin() && isValidProduct(request.resource.data);
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
